# Copia este archivo a `.env` y rellena la contraseña.
# `.env` está en .gitignore — NUNCA lo commitees.

# OJO: la base es `ceil_db`, NO `defaultdb` (esa está vacía).
# OJO: Aiven rechaza conexiones sin TLS, así que sslMode=REQUIRED, no useSSL=false.
CEIL_DB_URL=jdbc:mysql://mysql-288ee15e-ids-0d0d.g.aivencloud.com:15787/ceil_db?sslMode=REQUIRED
CEIL_DB_USER=avnadmin
CEIL_DB_PASSWORD=saca-esto-de-la-consola-de-aiven

# Puerto del servidor (por defecto 7000).
# En macOS el 7000 lo ocupa el receptor de AirPlay, usa otro.
CEIL_PORT=7070

# Secreto para firmar los tokens JWT (Fase 7). Debe ser largo y aleatorio.
# Si se cambia, todas las sesiones activas se invalidan (habrá que volver a entrar).
# Genera uno con:  openssl rand -base64 48
CEIL_JWT_SECRET=genera-uno-con-openssl-rand-base64-48