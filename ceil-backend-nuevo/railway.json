{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder": "RAILPACK",
    "buildCommand": "./gradlew build -x test"
  },
  "deploy": {
    "startCommand": "java -jar $(find build/libs -maxdepth 1 -name '*.jar' | head -n 1)",
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 10
  }
}
